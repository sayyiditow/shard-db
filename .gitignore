# Build output
build/
shard-db
shard-cli
shardkv
*.o
*.a

# Release artefacts (built tarballs sit at the repo root for upload)
shard-db-*.tar.gz

# ASan / sanitizer builds
*_asan
*_asan.log
bench-asan.log

# Runtime state — must never be committed
# Anchored to repo root so src/db/ (daemon source) isn't excluded.
/db/
/logs/
*.pid

# Per-instance config (operators populate these on the server)
tokens.conf
allowed_ips.conf

# Private ops scripts (not part of the public release)
drdb-setup.sh

# Editor / IDE
.history/
.vscode/
.idea/
*.swp
*.swo
*~

# Local Claude Code settings
.claude/settings.local.json

# OS junk
.DS_Store
Thumbs.db

# Temp benchmark artifacts
/tmp/shard-db_*
/tmp/shardkv_*

# Fuzzer build artifacts, mutation cache, and crash corpora.
# Auto-discovered corpus entries (sha-named) get cached in fuzz/.cache/
# to speed up subsequent local fuzz runs — fast to regenerate, not
# worth committing 22 MB of binary blobs. The committed fuzz/corpora/
# directory holds only the hand-written human-named seed inputs.
fuzz/build/
fuzz/.cache/
crash-*
leak-*
timeout-*
